---
const tracks = [
  { title: "I Just Had Sex", src: "/audio/I_Just_Had_Sex.mp3" },
  { title: "Time After Time", src: "/audio/Time_After_Time.mp3" },
  { title: "梦中的情话", src: "/audio/梦中的情话.mp3" },
  { title: "神话", src: "/audio/神话.mp3" },
  { title: "亡灵序曲", src: "/audio/亡灵序曲.mp3" },
  { title: "FFX", src: "/audio/SuTeKiDaNe.mp3" },
  { title: "Littl Wing", src: "/audio/Little_Wing.mp3" },
  { title: "Dying In The Sun", src: "/audio/Dying_in_the_sun.mp3" },
  { title: "冷雨夜", src: "/audio/冷雨夜.mp3" },
  { title: "Bittersweet", src: "/audio/Bittersweet.mp3" },
  { title: "In Perfect Harmony", src: "/audio/In_Perfect_Harmony.mp3" },
  { title: "没钱没朋友", src: "/audio/没钱没朋友.mp3" },
  { title: "凭什么我买单", src: "/audio/凭什么我买单.mp3" },
];
---

<div class="nav-music-player" id="navMusicPlayer">
  <audio id="bgMusic" preload="none"></audio>

  <div class="music-bar">
    <button id="prevTrackBtn" class="icon-btn" type="button" aria-label="Previous track">
      <span>⏮</span>
    </button>

    <button id="musicToggle" class="icon-btn play-btn" type="button" aria-label="Play or pause music">
      <span id="playIcon">▶</span>
    </button>

    <button id="nextTrackBtn" class="icon-btn" type="button" aria-label="Next track">
      <span>⏭</span>
    </button>

    <div class="music-meta">
      <div class="music-label">BGM</div>
      <button id="playlistToggle" class="music-title-btn" type="button" aria-label="Toggle playlist">
        <span id="musicTitle" class="music-title">{tracks[0].title}</span>
        <span class="music-caret">▾</span>
      </button>
    </div>

    <div class="volume-wrap">
      <span class="volume-icon">🔊</span>
      <input
        id="musicVolume"
        class="volume-slider"
        type="range"
        min="0"
        max="1"
        step="0.01"
        value="0.3"
        aria-label="Music volume"
      />
    </div>
  </div>

  <div id="playlistPanel" class="playlist-panel" hidden>
    <div class="playlist-head">
      <strong>播放列表</strong>
      <span>{tracks.length} 首</span>
    </div>

    <div class="playlist-list" id="playlistList">
      {tracks.map((track, index) => (
        <button
          type="button"
          class={`playlist-item ${index === 0 ? 'is-current' : ''}`}
          data-index={index}
        >
          <span class="playlist-index">{index + 1}</span>
          <span class="playlist-name">{track.title}</span>
        </button>
      ))}
    </div>
  </div>
</div>

<script define:vars={{ tracks }}>
  const STORAGE_KEY_VOLUME = "worldtrip-volume";

  const audio = document.getElementById("bgMusic");
  const toggleBtn = document.getElementById("musicToggle");
  const playIcon = document.getElementById("playIcon");
  const prevBtn = document.getElementById("prevTrackBtn");
  const nextBtn = document.getElementById("nextTrackBtn");
  const titleEl = document.getElementById("musicTitle");
  const playlistToggle = document.getElementById("playlistToggle");
  const playlistPanel = document.getElementById("playlistPanel");
  const playlistList = document.getElementById("playlistList");
  const volumeInput = document.getElementById("musicVolume");
  const playerRoot = document.getElementById("navMusicPlayer");

  let currentIndex = 0;
  let hasStarted = false;

  function getSavedVolume() {
    const saved = localStorage.getItem(STORAGE_KEY_VOLUME);
    const parsed = saved ? Number(saved) : 0.3;
    if (Number.isNaN(parsed)) return 0.3;
    return Math.min(1, Math.max(0, parsed));
  }

  function updatePlaylistUI() {
    if (!playlistList) return;
    const items = playlistList.querySelectorAll(".playlist-item");
    items.forEach((item, index) => {
      if (index === currentIndex) {
        item.classList.add("is-current");
      } else {
        item.classList.remove("is-current");
      }
    });
  }

  function updatePlayStateUI(isPlaying) {
    if (playIcon) {
      playIcon.textContent = isPlaying ? "❚❚" : "▶";
    }
    if (toggleBtn) {
      toggleBtn.classList.toggle("is-playing", isPlaying);
    }
  }

  function loadTrack(index) {
    if (!audio) return;
    currentIndex = index;
    audio.src = tracks[currentIndex].src;
    if (titleEl) titleEl.textContent = tracks[currentIndex].title;
    updatePlaylistUI();

    const savedVolume = getSavedVolume();
    audio.volume = savedVolume;
    if (volumeInput) volumeInput.value = String(savedVolume);
  }

  async function playCurrentTrack() {
    if (!audio) return;
    try {
      await audio.play();
      updatePlayStateUI(true);
    } catch (err) {
      console.error("Playback failed:", err);
    }
  }

  function pauseCurrentTrack() {
    if (!audio) return;
    audio.pause();
    updatePlayStateUI(false);
  }

  async function goToTrack(index) {
    loadTrack(index);
    hasStarted = true;
    await playCurrentTrack();
  }

  async function nextTrack() {
    const nextIndex = (currentIndex + 1) % tracks.length;
    await goToTrack(nextIndex);
  }

  async function prevTrack() {
    const prevIndex = (currentIndex - 1 + tracks.length) % tracks.length;
    await goToTrack(prevIndex);
  }

  function togglePlaylist() {
    if (!playlistPanel) return;
    const willOpen = playlistPanel.hasAttribute("hidden");
    if (willOpen) {
      playlistPanel.removeAttribute("hidden");
    } else {
      playlistPanel.setAttribute("hidden", "");
    }
  }

  loadTrack(0);
  updatePlayStateUI(false);

  toggleBtn?.addEventListener("click", async () => {
    if (!audio) return;

    if (!hasStarted) {
      hasStarted = true;
      await playCurrentTrack();
      return;
    }

    if (audio.paused) {
      await playCurrentTrack();
    } else {
      pauseCurrentTrack();
    }
  });

  nextBtn?.addEventListener("click", async () => {
    await nextTrack();
  });

  prevBtn?.addEventListener("click", async () => {
    await prevTrack();
  });

  playlistToggle?.addEventListener("click", () => {
    togglePlaylist();
  });

  playlistList?.addEventListener("click", async (event) => {
    const target = event.target.closest(".playlist-item");
    if (!target) return;
    const index = Number(target.dataset.index);
    if (Number.isNaN(index)) return;
    await goToTrack(index);
  });

  volumeInput?.addEventListener("input", (event) => {
    if (!audio) return;
    const value = Number(event.target.value);
    audio.volume = value;
    localStorage.setItem(STORAGE_KEY_VOLUME, String(value));
  });

  audio?.addEventListener("ended", async () => {
    await nextTrack();
  });

  audio?.addEventListener("pause", () => {
    updatePlayStateUI(false);
  });

  audio?.addEventListener("play", () => {
    updatePlayStateUI(true);
  });

  document.addEventListener("click", (event) => {
    if (!playerRoot || !playlistPanel) return;
    if (playlistPanel.hasAttribute("hidden")) return;

    if (!playerRoot.contains(event.target)) {
      playlistPanel.setAttribute("hidden", "");
    }
  });
</script>

<style>
  .nav-music-player {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;
    min-width: 420px;
    max-width: 520px;
  }

  .music-bar {
    display: grid;
    grid-template-columns: auto auto auto minmax(120px, 1fr) auto;
    align-items: center;
    gap: 10px;
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: var(--panel-strong);
    border: 1px solid var(--line);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
  }

  .icon-btn {
    width: 2.2rem;
    height: 2.2rem;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    background: var(--accent-soft);
    color: var(--text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
    flex-shrink: 0;
  }

  .icon-btn:hover {
    transform: translateY(-1px);
  }

  .play-btn.is-playing {
    box-shadow: 0 0 0 6px rgba(255, 255, 255, 0.05);
  }

  .music-meta {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
  }

  .music-label {
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-left: 2px;
  }

  .music-title-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    text-align: left;
    min-width: 0;
  }

  .music-title {
    font-size: 0.92rem;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .music-caret {
    color: var(--muted);
    flex-shrink: 0;
    font-size: 0.82rem;
  }

  .volume-wrap {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-width: 120px;
  }

  .volume-icon {
    font-size: 0.9rem;
    color: var(--muted);
    flex-shrink: 0;
  }

  .volume-slider {
    width: 92px;
    accent-color: var(--accent);
    cursor: pointer;
  }

  .playlist-panel {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    width: 100%;
    border-radius: 22px;
    border: 1px solid var(--line);
    background: var(--panel-strong);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.12);
    padding: 14px;
    z-index: 30;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .playlist-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
    padding: 2px 4px 10px;
    border-bottom: 1px solid var(--line);
  }

  .playlist-head strong {
    font-size: 0.95rem;
    color: var(--text);
  }

  .playlist-head span {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .playlist-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 260px;
    overflow: auto;
    padding-right: 2px;
  }

  .playlist-item {
    display: grid;
    grid-template-columns: 26px minmax(0, 1fr);
    align-items: center;
    gap: 10px;
    width: 100%;
    border: none;
    border-radius: 14px;
    background: transparent;
    color: var(--text);
    text-align: left;
    padding: 10px 12px;
    cursor: pointer;
    transition: background 0.18s ease, transform 0.18s ease;
  }

  .playlist-item:hover {
    background: var(--accent-soft);
    transform: translateY(-1px);
  }

  .playlist-item.is-current {
    background: var(--accent-soft);
    box-shadow: inset 0 0 0 1px var(--line);
  }

  .playlist-index {
    color: var(--muted);
    font-size: 0.84rem;
  }

  .playlist-name {
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.92rem;
  }

  @media (max-width: 1180px) {
    .nav-music-player {
      min-width: 360px;
      max-width: 440px;
    }

    .volume-wrap {
      min-width: 96px;
    }

    .volume-slider {
      width: 72px;
    }
  }

  @media (max-width: 720px) {
    .nav-music-player {
      min-width: 100%;
      max-width: 100%;
    }

    .music-bar {
      grid-template-columns: auto auto auto minmax(0, 1fr);
    }

    .volume-wrap {
      display: none;
    }
  }
</style>