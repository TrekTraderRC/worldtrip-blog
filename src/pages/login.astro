---
export const prerender = false;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Login 夜色风月 World X Trip 世界游记</title>
    <style>
      body {
        margin: 0;
        font-family: Inter, "PingFang SC", "Microsoft YaHei", sans-serif;
        background: #0c0b14;
        color: #f7f2ff;
      }
      .wrap {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
      }
      .card {
        width: 100%;
        max-width: 520px;
        background: rgba(24, 27, 46, 0.92);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 28px;
      }
      h1 {
        margin-top: 0;
        margin-bottom: 10px;
      }
      .sub {
        color: #b8a8d6;
        line-height: 1.7;
        margin-bottom: 22px;
      }
      .field {
        margin-bottom: 14px;
      }
      label {
        display: block;
        margin-bottom: 8px;
      }
      input {
        width: 100%;
        height: 48px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.12);
        background: #121422;
        color: #fff;
        padding: 0 14px;
        box-sizing: border-box;
      }
      button {
        width: 100%;
        height: 46px;
        border: 0;
        border-radius: 999px;
        font-weight: 700;
        cursor: pointer;
      }
      .primary {
        background: #6ae2ff;
        color: #111;
      }
      .secondary {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.12);
      }
      .oauths {
        display: grid;
        gap: 10px;
        margin-top: 18px;
      }
      .divider {
        margin: 22px 0 18px;
        text-align: center;
        color: #9988b8;
        font-size: 13px;
      }
      .message {
        margin-top: 12px;
        font-size: 14px;
        line-height: 1.7;
        color: #d9d0ef;
        min-height: 24px;
      }
      .hint {
        margin-top: 18px;
        font-size: 13px;
        color: #9988b8;
        line-height: 1.7;
      }
      .step {
        display: none;
      }
      .step.active {
        display: block;
      }
      .minor-action {
        margin-top: 12px;
        background: transparent;
        color: #b8a8d6;
        border: 1px solid rgba(255,255,255,0.10);
      }
      a { color: #ff4fd8; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="card">
        <h1>继续访问</h1>
        <div class="sub">
          输入邮箱，我们会发送一次性验证码。<br />
          如果这是你第一次访问，账号会自动创建。
        </div>

        <div id="step-email" class="step active">
          <form id="email-form">
            <div class="field">
              <label for="email">邮箱</label>
              <input id="email" name="email" type="email" required />
            </div>

            <button class="primary" type="submit">发送验证码</button>
          </form>
        </div>

        <div id="step-otp" class="step">
          <form id="otp-form">
            <div class="field">
              <label for="otp">验证码</label>
              <input
                id="otp"
                name="otp"
                type="text"
                inputmode="numeric"
                autocomplete="one-time-code"
                placeholder="请输入邮箱中的验证码"
                required
              />
            </div>

            <button class="primary" type="submit">验证并登录</button>
            <button class="minor-action" id="back-btn" type="button">返回修改邮箱</button>
          </form>
        </div>

        <div class="message" id="message"></div>

        <div class="divider">或者</div>

        <div class="oauths">
          <button class="secondary" id="google-btn" type="button">
            Continue with Google
          </button>

          <button class="secondary" id="facebook-btn" type="button">
            Continue with Facebook
          </button>
        </div>

        <div class="hint">
          登录后可在 <a href="/account">我的账户</a> 查看会员状态。
        </div>
      </div>
    </div>

    <script>
      import { getSupabaseBrowserClient } from '../lib/supabase/client.ts';

      const supabase = getSupabaseBrowserClient();

      const emailForm = document.getElementById('email-form') as HTMLFormElement | null;
      const otpForm = document.getElementById('otp-form') as HTMLFormElement | null;

      const emailInput = document.getElementById('email') as HTMLInputElement | null;
      const otpInput = document.getElementById('otp') as HTMLInputElement | null;

      const stepEmail = document.getElementById('step-email') as HTMLDivElement | null;
      const stepOtp = document.getElementById('step-otp') as HTMLDivElement | null;

      const backBtn = document.getElementById('back-btn') as HTMLButtonElement | null;
      const message = document.getElementById('message') as HTMLDivElement | null;

      const googleBtn = document.getElementById('google-btn') as HTMLButtonElement | null;
      const facebookBtn = document.getElementById('facebook-btn') as HTMLButtonElement | null;

      let pendingEmail = '';

      function showStep(step: 'email' | 'otp') {
        if (!stepEmail || !stepOtp) return;

        stepEmail.classList.toggle('active', step === 'email');
        stepOtp.classList.toggle('active', step === 'otp');
      }

      emailForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!message || !emailInput) return;

        const email = emailInput.value.trim();
        if (!email) {
          message.textContent = '请输入邮箱地址。';
          return;
        }

        message.textContent = '正在发送验证码...';

        const { error } = await supabase.auth.signInWithOtp({
          email,
          options: {
            shouldCreateUser: true,
          },
        });

        if (error) {
          message.textContent = `发送失败：${error.message}`;
          return;
        }

        pendingEmail = email;
        showStep('otp');
        message.textContent = '验证码已发送，请检查邮箱并输入验证码。';
        otpInput?.focus();
      });

      otpForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!message || !otpInput) return;

        const token = otpInput.value.trim();
        if (!pendingEmail) {
          message.textContent = '邮箱信息丢失，请重新发送验证码。';
          showStep('email');
          return;
        }

        if (!token) {
          message.textContent = '请输入验证码。';
          return;
        }

        message.textContent = '正在验证验证码...';

        const { error } = await supabase.auth.verifyOtp({
          email: pendingEmail,
          token,
          type: 'email',
        });

        if (error) {
          message.textContent = `验证失败：${error.message}`;
          return;
        }

        message.textContent = '登录成功，正在跳转...';
        window.location.href = '/account';
      });

      backBtn?.addEventListener('click', () => {
        if (!message) return;
        showStep('email');
        message.textContent = '';
      });

      googleBtn?.addEventListener('click', async () => {
        if (!message) return;

        message.textContent = '正在跳转到 Google...';

        const { error } = await supabase.auth.signInWithOAuth({
          provider: 'google',
          options: {
            redirectTo: `${window.location.origin}/account`,
          },
        });

        if (error) {
          message.textContent = `Google 登录失败：${error.message}`;
        }
      });

      facebookBtn?.addEventListener('click', async () => {
        if (!message) return;
        message.textContent = 'Facebook 登录暂未配置。';
      });
    </script>
  </body>
</html>