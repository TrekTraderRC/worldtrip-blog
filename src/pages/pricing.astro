---
import ThemeToggle from '../components/ThemeToggle.astro';

export const prerender = false;

const currentUser = Astro.locals.user;
const subscribeHref = currentUser ? '/subscribe' : '/login';
const subscribeLabel = currentUser ? '查看付款方式' : '登录后订阅';
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>订阅方案 - 夜色风月 World X Trip 世界游记</title>
    <meta
      name="description"
      content="支持 World X Trip 的持续写作，并解锁更完整、更及时的深度游记与延伸档案。"
    />
    <style>
      :root {
        --bg: #f8f3f8;
        --bg-soft: #fcf7fc;
        --panel: rgba(255, 255, 255, 0.76);
        --panel-strong: rgba(255, 255, 255, 0.92);

        --text: #20171f;
        --muted: #7d6879;

        --line: rgba(80, 42, 72, 0.1);
        --line-strong: rgba(80, 42, 72, 0.16);

        --accent: #b05c8e;
        --accent-2: #d88cc8;
        --accent-soft: rgba(176, 92, 142, 0.1);

        --shadow: 0 18px 44px rgba(113, 61, 104, 0.1);
      }

      :root[data-theme='dark'] {
        --bg: #0c0b14;
        --bg-soft: #131222;
        --panel: rgba(18, 20, 34, 0.78);
        --panel-strong: rgba(24, 27, 46, 0.92);

        --text: #f7f2ff;
        --muted: #b8a8d6;

        --line: rgba(120, 104, 255, 0.18);
        --line-strong: rgba(255, 79, 216, 0.26);

        --accent: #ff4fd8;
        --accent-2: #6ae2ff;
        --accent-soft: rgba(255, 79, 216, 0.14);

        --shadow: 0 20px 52px rgba(0, 0, 0, 0.28);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Noto Serif SC", "Songti SC", "Source Han Serif SC",
          "PingFang SC", "Microsoft YaHei", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(216, 140, 200, 0.14), transparent 30%),
          radial-gradient(circle at top right, rgba(176, 92, 142, 0.1), transparent 26%),
          radial-gradient(circle at bottom center, rgba(106, 226, 255, 0.08), transparent 36%),
          var(--bg);
      }

      a {
        color: inherit;
      }

      .container {
        max-width: 1180px;
        margin: 0 auto;
        padding: 24px 24px 88px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
      }

      .topbar-actions {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .back-link {
        text-decoration: none;
        color: var(--muted);
        font-size: 14px;
        font-weight: 600;
      }

      .back-link:hover {
        color: var(--text);
      }

      .hero,
      .value-section,
      .faq,
      .footer-card,
      .process-section {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: var(--shadow);
      }

      .hero {
        border-radius: 30px;
        padding: 36px 32px;
        margin-bottom: 24px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 18px 0 14px;
        font-size: clamp(34px, 5vw, 56px);
        line-height: 1.1;
        letter-spacing: -0.03em;
        max-width: 25ch;
      }

      .hero p {
        margin: 0;
        max-width: 48em;
        color: var(--muted);
        line-height: 1.95;
        font-size: 17px;
      }

      .hero-quote {
        margin-top: 18px;
        color: var(--accent);
        font-size: 15px;
        line-height: 1.8;
      }

      .plans-wrap {
        display: grid;
        gap: 18px;
        margin-bottom: 24px;
      }

      .plans-row {
        display: grid;
        gap: 18px;
      }

      .plans-row.top {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .plans-row.bottom {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .plan {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: var(--shadow);
        border-radius: 26px;
        padding: 24px;
        position: relative;
        overflow: hidden;
      }

      .plan.featured {
        border-color: var(--line-strong);
        box-shadow:
          var(--shadow),
          0 0 0 1px rgba(255, 79, 216, 0.12);
      }

      .plan.lifetime {
        border-color: var(--line-strong);
      }

      .plan-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 14px;
        background: var(--accent-soft);
        color: var(--accent);
      }

      .plan h2 {
        margin: 0 0 10px;
        font-size: 28px;
        letter-spacing: -0.03em;
        line-height: 1.2;
      }

      .price {
        display: flex;
        align-items: baseline;
        gap: 8px;
        margin-bottom: 14px;
      }

      .price strong {
        font-size: 42px;
        line-height: 1;
        letter-spacing: -0.04em;
      }

      .price span {
        color: var(--muted);
        font-size: 15px;
      }

      .plan p {
        margin: 0 0 18px;
        color: var(--muted);
        line-height: 1.9;
      }

      .features {
        list-style: none;
        padding: 0;
        margin: 0 0 22px;
        display: grid;
        gap: 12px;
      }

      .features li {
        padding: 12px 14px;
        border-radius: 16px;
        background: var(--panel-strong);
        border: 1px solid var(--line);
        line-height: 1.75;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        line-height: 1;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
        cursor: pointer;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button-primary {
        background: var(--text);
        color: var(--bg);
      }

      .button-primary:hover {
        box-shadow: 0 0 0 1px rgba(255, 79, 216, 0.18), 0 0 20px rgba(255, 79, 216, 0.12);
      }

      .button-secondary {
        border: 1px solid var(--line-strong);
        background: transparent;
      }

      .process-section {
        border-radius: 28px;
        padding: 26px;
        margin-bottom: 24px;
      }

      .process-section h3,
      .value-section h3,
      .faq h3 {
        margin: 0 0 18px;
        font-size: 28px;
        letter-spacing: -0.03em;
      }

      .process-grid,
      .value-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
      }

      .process-item,
      .value-item {
        padding: 18px;
        border-radius: 20px;
        background: var(--panel-strong);
        border: 1px solid var(--line);
      }

      .process-item strong,
      .value-item strong {
        display: block;
        margin-bottom: 10px;
        font-size: 16px;
      }

      .process-item p,
      .value-item p {
        margin: 0;
        color: var(--muted);
        line-height: 1.85;
        font-size: 14px;
      }

      .value-section {
        border-radius: 28px;
        padding: 26px;
        margin-bottom: 24px;
      }

      .faq {
        border-radius: 28px;
        padding: 26px;
        margin-bottom: 24px;
      }

      .faq-grid {
        display: grid;
        gap: 14px;
      }

      .faq-item {
        padding: 16px 18px;
        border-radius: 18px;
        background: var(--panel-strong);
        border: 1px solid var(--line);
      }

      .faq-item strong {
        display: block;
        margin-bottom: 8px;
        font-size: 16px;
      }

      .faq-item p {
        margin: 0;
        color: var(--muted);
        line-height: 1.9;
      }

      .footer-card {
        border-radius: 24px;
        padding: 22px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
      }

      .footer-card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.85;
        max-width: 55em;
        font-size: 14px;
      }

      @media (max-width: 980px) {
        .plans-row.top,
        .plans-row.bottom,
        .value-grid,
        .process-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .container {
          padding: 18px 16px 68px;
        }

        .hero,
        .process-section,
        .value-section,
        .faq,
        .footer-card,
        .plan {
          border-radius: 22px;
          padding: 20px 18px;
        }

        h1 {
          max-width: none;
          font-size: 32px;
        }

        .plan h2 {
          font-size: 24px;
        }

        .price strong {
          font-size: 34px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="topbar">
        <a class="back-link" href="/">← 返回首页</a>

        <div class="topbar-actions">
          <a class="back-link" href={currentUser ? '/account' : '/login'}>
            {currentUser ? '我的账户' : '会员登录'}
          </a>
          <ThemeToggle />
        </div>
      </div>

      <section class="hero">
        <span class="eyebrow">读者支持计划</span>
        <h1>黑夜给了你黑色的眼睛，请用黑色的眼睛去寻找夜色的浪漫与神秘。</h1>
        <p>
          这里的付费内容，不只是更完整的长文。
          很多城市、场所与人物的变化都非常快，有些值得记录的信息，
          适合写成更完整的延伸档案，而不是只在公开页留下简短摘要。
        </p>
        <p style="margin-top: 12px;">
          因此，订阅的价值除了看得更全，也在于看得更及时。
          对真正持续关注这些城市切片、夜生活观察与旅行记述的人来说，
          更新速度本身就是内容价值的一部分。
        </p>
        <div class="hero-quote">
          风月故事需要细品回味，夜色情报必须及时更新。
        </div>
      </section>

      <section class="plans-wrap">
        <div class="plans-row top">
          <article class="plan">
            <div class="plan-badge">免费</div>
            <h2>开放浏览</h2>
            <div class="price">
              <strong>$0</strong>
              <span>/ 永久</span>
            </div>
            <p>
              适合初来乍到，或只想轻量浏览的读者。
            </p>

            <ul class="features">
              <li>浏览所有免费内容</li>
              <li>开启探索之旅</li>
              <li>从公开内容开始阅读</li>
            </ul>

            <a class="button button-secondary" href="/">开始阅读</a>
          </article>

          <article class="plan">
            <div class="plan-badge">短期通行</div>
            <h2>1个月</h2>
            <div class="price">
              <strong>$9</strong>
              <span>/ 月</span>
            </div>
            <p>
              适合短期集中查看、旅行前做功课，或先试订一个月。
            </p>

            <ul class="features">
              <li><strong>解锁全部付费内容</strong></li>
              <li>适合短期集中阅读</li>
              <li>体验完整更新节奏</li>
            </ul>

            <a class="button button-primary" href={subscribeHref}>{subscribeLabel}</a>
          </article>

          <article class="plan featured">
            <div class="plan-badge">推荐</div>
            <h2>6个月</h2>
            <div class="price">
              <strong>$45</strong>
              <span>/ 半年</span>
            </div>
            <p>
              适合持续跟踪多个地区更新，比较均衡的选择。
            </p>

            <ul class="features">
              <li><strong>解锁全部付费内容</strong></li>
              <li>持续跟踪多个国家 / 城市更新</li>
              <li>更适合体会“更新迅速”的价值</li>
            </ul>

            <a class="button button-primary" href={subscribeHref}>{subscribeLabel}</a>
          </article>
        </div>

        <div class="plans-row bottom">
          <article class="plan">
            <div class="plan-badge">全年档案</div>
            <h2>1年</h2>
            <div class="price">
              <strong>$90</strong>
              <span>/ 年</span>
            </div>
            <p>
              适合长期关注全球信息动向与城市演变的读者。
            </p>

            <ul class="features">
              <li><strong>解锁全部付费内容</strong></li>
              <li>适合长期阅读与持续关注</li>
              <li>更完整跟踪内容积累与更新脉络</li>
            </ul>

            <a class="button button-primary" href={subscribeHref}>{subscribeLabel}</a>
          </article>

          <article class="plan lifetime">
            <div class="plan-badge">一次买断</div>
            <h2>终生会员</h2>
            <div class="price">
              <strong>$130</strong>
              <span>/ 终生</span>
            </div>
            <p>
              适合认可这个站点长期价值，希望一次买断全部访问权限的读者。
            </p>

            <ul class="features">
              <li><strong>永久解锁全部付费内容</strong></li>
              <li>后续新增内容持续可见</li>
              <li>一次开通，长期访问</li>
            </ul>

            <a class="button button-primary" href={subscribeHref}>{subscribeLabel}</a>
          </article>
        </div>
      </section>

      <section class="process-section">
        <h3>当前开通流程</h3>

        <div class="process-grid">
          <div class="process-item">
            <strong>先登录</strong>
            <p>
              请先登录网站。这样付款后，会员权限才能与当前账号正确匹配。
            </p>
          </div>

          <div class="process-item">
            <strong>查看付款方式</strong>
            <p>
              已登录用户可进入付款说明页，按照页面里的二维码或付款方式完成支付。
            </p>
          </div>

          <div class="process-item">
            <strong>审核开通</strong>
            <p>
              付款完成后，请提供登录邮箱、付款截图与购买方案。审核通过后即可解锁付费内容。
            </p>
          </div>
        </div>
      </section>

      <section class="value-section">
        <h3>为什么订阅值得</h3>

        <div class="value-grid">
          <div class="value-item">
            <strong>全部内容解锁</strong>
            <p>
              包括完整游记、深入记录、延伸档案，以及那些不适合只写成摘要的片段。
            </p>
          </div>

          <div class="value-item">
            <strong>更新更快</strong>
            <p>
              某些城市切片、夜生活观察与现场信息变化很快。订阅用户能更快看到新增内容与更新整理。
            </p>
          </div>

          <div class="value-item">
            <strong>不只是故事，也是信息</strong>
            <p>
              这里记录的不是空泛想象，而是价格、氛围、体验与变化，也会侧面反映当地消费气候与城市肌理。
            </p>
          </div>
        </div>
      </section>

      <section class="faq">
        <h3>常见问题</h3>

        <div class="faq-grid">
          <div class="faq-item">
            <strong>现在已经可以付款了吗？</strong>
            <p>
              可以，但支付后还有审核流程。请先登录，再进入付款说明页，完成付款后把登录邮箱、付款截图与购买方案发送邮件到 etnavax56@gmail.com。
            </p>
          </div>

          <div class="faq-item">
            <strong>付款后会自动开通吗？</strong>
            <p>
              暂时不会，需要审核通过后才可以解锁付费内容。
            </p>
          </div>

          <div class="faq-item">
            <strong>付款后需要提供什么信息？</strong>
            <p>
              请至少提供：站内登录邮箱、付款截图、购买方案。若付款账户与登录邮箱不同，也请一并说明。
            </p>
          </div>

          <div class="faq-item">
            <strong>所有付费档位的区别是什么？</strong>
            <p>
              所有付费档位都会解锁全部付费内容，区别只在于有效时长。
            </p>
          </div>

          <!-- <div class="faq-item">
            <strong>FAQ项目占位符</strong>
            <p>
              FAQ项目占位符，后续新的FAQ项目可按此格式添加。
            </p>
          </div> -->
        </div>
      </section>

      <footer class="footer-card">
        <p>
          千金难买好时光，与其纠结不如纵狂，呼朋引伴、举杯同乐、销尽万古愁思肠。若得此生常尽兴，不羡长生不羡仙！
        </p>

        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a class="button button-secondary" href="/">返回首页</a>
          <a class="button button-primary" href={subscribeHref}>{subscribeLabel}</a>
        </div>
      </footer>
    </div>
  </body>
</html>