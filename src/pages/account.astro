---
export const prerender = false;

const user = Astro.locals.user;
const membership = Astro.locals.membership;
const hasPaidAccess = Astro.locals.hasPaidAccess;

if (!user) {
  return Astro.redirect('/login');
}
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>我的账户 - 夜色风月 World X Trip 世界游记</title>
    <style>
      body {
        margin: 0;
        font-family: Inter, "PingFang SC", "Microsoft YaHei", sans-serif;
        background: #0c0b14;
        color: #f7f2ff;
      }
      .wrap {
        max-width: 860px;
        margin: 0 auto;
        padding: 32px 20px 80px;
      }
      .card {
        background: rgba(24, 27, 46, 0.92);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 18px;
      }
      h1, h2 { margin-top: 0; }
      .row { margin: 10px 0; color: #d8cfee; }
      .ok { color: #6ae2ff; }
      .warn { color: #ff8ee7; }
      .actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 18px;
      }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        line-height: 1;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
        cursor: pointer;
        appearance: none;
        -webkit-appearance: none;
        background: none;
        font-family: inherit;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button:focus {
        outline: none;
      }

      .button-primary {
        background: #ff4fd8;
        color: #111;
        border: 0;
      }

      .button-primary:hover {
        box-shadow: 0 0 0 1px rgba(255, 79, 216, 0.18), 0 0 20px rgba(255, 79, 216, 0.12);
      }

      .button-secondary {
        border: 1px solid rgba(255,255,255,0.14);
        color: #fff;
        background: transparent;
      }

      .button-secondary:hover {
        box-shadow: 0 0 0 1px rgba(255,255,255,0.08);
      }
      button.button {
        border-width: 1px;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="card">
        <h1>我的账户</h1>
        <div class="row">邮箱：{user.email ?? '未读取到邮箱'}</div>
        <div class="row">
          当前访问权限：
          <strong class={hasPaidAccess ? 'ok' : 'warn'}>
            {hasPaidAccess ? '已解锁付费内容' : '暂无有效付费权限'}
          </strong>
        </div>
      </div>

      <div class="card">
        <h2>会员状态</h2>

        {membership ? (
          <>
            <div class="row">方案：{membership.plan}</div>
            <div class="row">状态：{membership.status}</div>
            <div class="row">开始时间：{membership.start_at ?? '—'}</div>
            <div class="row">结束时间：{membership.is_lifetime ? '终生' : membership.end_at ?? '—'}</div>
            <div class="row">终生会员：{membership.is_lifetime ? '是' : '否'}</div>
            {membership.notes ? <div class="row">备注：{membership.notes}</div> : null}
          </>
        ) : (
          <div class="row">你当前还没有有效或已记录的会员信息。</div>
        )}

        <div class="actions">
          <a class="button button-primary" href="/pricing">查看订阅方案</a>
          <a class="button button-secondary" href="/">返回首页</a>
          <button class="button button-secondary" id="logout-btn" type="button">退出登录</button>
        </div>
      </div>
    </div>

    <script>
      import { getSupabaseBrowserClient } from '../lib/supabase/client.ts';

      const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement | null;

      logoutBtn?.addEventListener('click', async () => {
        const supabase = getSupabaseBrowserClient();

        await supabase.auth.signOut();
        window.location.href = '/';
      });
    </script>
  </body>
</html>