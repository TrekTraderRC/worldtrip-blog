---
export const prerender = false;

import CollectionWheel from '../components/CollectionWheel.jsx';
import {
  constellationItems,
  zodiacItems,
  getCollectionStats,
} from '../data/collectionData.js';

const user = Astro.locals.user;
const hasPaidAccess = Astro.locals.hasPaidAccess;

const constellationStats = getCollectionStats(constellationItems);
const zodiacStats = getCollectionStats(zodiacItems);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>夜色图鉴 Collection - 夜色风月 World X Trip 世界游记</title>
    <meta
      name="description"
      content="夜色图鉴收藏页，记录星座与生肖成就盘。"
    />

    <style is:global>
      :root {
        --bg: #05070d;
        --bg-2: #0a1020;
        --panel: rgba(14, 18, 32, 0.94);
        --panel-2: rgba(19, 25, 42, 0.94);
        --line: rgba(124, 156, 255, 0.14);
        --line-strong: rgba(115, 220, 255, 0.26);
        --text: #f7f3ff;
        --muted: #9aa6cb;
        --soft: #dbe3ff;
        --cyan: #73dcff;
        --blue: #7a96ff;
        --violet: #9e83ff;
        --pink: #ff73da;
        --gold: #f3d588;
        --shadow: 0 24px 60px rgba(0, 0, 0, 0.34);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Inter, "PingFang SC", "Microsoft YaHei", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 50% 0%, rgba(115, 220, 255, 0.08), transparent 24%),
          radial-gradient(circle at 18% 14%, rgba(158, 131, 255, 0.08), transparent 24%),
          radial-gradient(circle at 82% 14%, rgba(255, 115, 218, 0.06), transparent 20%),
          linear-gradient(180deg, #04060d 0%, #081020 58%, #05070d 100%);
      }

      a {
        color: inherit;
      }

      .wrap {
        max-width: 1360px;
        margin: 0 auto;
        padding: 28px 24px 90px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 26px;
      }

      .back-link {
        text-decoration: none;
        color: var(--muted);
        font-size: 14px;
        font-weight: 700;
      }

      .back-link:hover {
        color: var(--text);
      }

      .account-link {
        display: inline-flex;
        align-items: center;
        min-height: 42px;
        padding: 0 16px;
        border-radius: 999px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(255,255,255,0.03);
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }

      .account-link:hover {
        transform: translateY(-1px);
        box-shadow: 0 0 20px rgba(115, 220, 255, 0.08);
        border-color: rgba(115, 220, 255, 0.18);
      }

      .hero-card,
      .gate-card,
      .placeholder-card {
        border-radius: 28px;
        border: 1px solid var(--line);
        background: var(--panel);
        box-shadow: var(--shadow);
      }

      .hero-card {
        position: relative;
        overflow: hidden;
        padding: 34px 30px;
        margin-bottom: 24px;
      }

      .hero-card::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
          radial-gradient(circle at top right, rgba(115, 220, 255, 0.10), transparent 24%),
          radial-gradient(circle at bottom left, rgba(158, 131, 255, 0.10), transparent 28%);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(115, 220, 255, 0.08);
        color: var(--cyan);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 18px 0 14px;
        font-size: clamp(34px, 4.8vw, 68px);
        line-height: 1.02;
        letter-spacing: -0.05em;
      }

      .hero-copy {
        max-width: 74ch;
        margin: 0;
        color: var(--muted);
        line-height: 1.9;
        font-size: 15px;
      }

      .stats-grid {
        margin-top: 24px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
      }

      .stat-card {
        border-radius: 24px;
        padding: 20px 20px 18px;
        background: linear-gradient(180deg, rgba(22, 28, 48, 0.94), rgba(16, 21, 38, 0.94));
        border: 1px solid rgba(124, 156, 255, 0.16);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.03),
          0 0 24px rgba(115, 220, 255, 0.03);
      }

      .stat-kicker {
        color: var(--cyan);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 10px;
      }

      .stat-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
      }

      .stat-title {
        margin: 0;
        font-size: 28px;
        letter-spacing: -0.03em;
      }

      .stat-main {
        font-size: 38px;
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.05em;
      }

      .stat-sub {
        color: var(--muted);
        font-size: 14px;
        line-height: 1.75;
      }

      .gate-card {
        padding: 32px 28px;
        margin-top: 24px;
        text-align: center;
      }

      .gate-title {
        margin: 0 0 12px;
        font-size: 30px;
        letter-spacing: -0.03em;
      }

      .gate-copy {
        max-width: 58ch;
        margin: 0 auto;
        color: var(--muted);
        line-height: 1.9;
      }

      .gate-actions {
        display: flex;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 24px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 18px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 800;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button-primary {
        background: linear-gradient(90deg, var(--cyan), var(--pink));
        color: #081018;
        border: 0;
      }

      .button-secondary {
        border: 1px solid rgba(255,255,255,0.12);
        color: var(--text);
        background: rgba(255,255,255,0.03);
      }

      .wheels-grid {
        margin-top: 28px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 24px;
      }

      .wheel-panel {
        border-radius: 30px;
        border: 1px solid var(--line);
        background:
          radial-gradient(circle at top center, rgba(115, 220, 255, 0.05), transparent 24%),
          linear-gradient(180deg, rgba(14,18,32,0.98), rgba(7,10,20,0.98));
        box-shadow: var(--shadow);
        padding: 22px 22px 26px;
      }

      .wheel-panel-head {
        margin-bottom: 6px;
      }

      .wheel-kicker {
        color: var(--cyan);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        opacity: 0.96;
      }

      .wheel-title {
        margin: 8px 0 0;
        font-size: 22px;
        letter-spacing: -0.03em;
      }

      .wheel-shell {
        position: relative;
        width: min(100%, 520px);
        aspect-ratio: 1 / 1;
        margin: 14px auto 0;
        border-radius: 50%;
        background:
          radial-gradient(circle at center, rgba(255,255,255,0.02), transparent 30%),
          radial-gradient(circle at center, rgba(115, 220, 255, 0.08), transparent 48%),
          radial-gradient(circle at 50% 48%, rgba(243, 213, 136, 0.05), transparent 18%),
          linear-gradient(180deg, rgba(15, 20, 36, 0.96), rgba(7, 10, 20, 0.98));
        overflow: hidden;
        box-shadow:
          inset 0 0 40px rgba(115, 220, 255, 0.05),
          0 0 30px rgba(115, 220, 255, 0.05);
      }

      .wheel-glow {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        filter: blur(20px);
      }

      .wheel-glow-a {
        inset: 10% 10% auto auto;
        width: 120px;
        height: 120px;
        background: rgba(115, 220, 255, 0.08);
      }

      .wheel-glow-b {
        inset: auto auto 12% 14%;
        width: 110px;
        height: 110px;
        background: rgba(158, 131, 255, 0.07);
      }

      .wheel-ring {
        position: absolute;
        inset: 50%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
      }

      .wheel-ring-outer {
        width: 96%;
        height: 96%;
        border: 1px solid rgba(136, 170, 255, 0.14);
        box-shadow:
          0 0 0 1px rgba(115, 220, 255, 0.04),
          0 0 24px rgba(115, 220, 255, 0.05);
      }

      .wheel-ring-mid {
        width: 72%;
        height: 72%;
        border: 1px solid rgba(136, 170, 255, 0.12);
      }

      .wheel-ring-inner {
        width: 34%;
        height: 34%;
        border: 1px solid rgba(136, 170, 255, 0.12);
      }

      .wheel-center {
        position: absolute;
        inset: 50%;
        width: 30%;
        height: 30%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.08);
        background:
          radial-gradient(circle at center, rgba(243, 213, 136, 0.22), rgba(243, 213, 136, 0.08) 42%, transparent 72%),
          linear-gradient(180deg, rgba(30,36,58,0.98), rgba(10,14,24,0.98));
        display: grid;
        place-items: center;
        text-align: center;
        padding: 14px;
        box-shadow:
          inset 0 0 24px rgba(243, 213, 136, 0.12),
          0 0 26px rgba(243, 213, 136, 0.10);
      }

      .wheel-center-label {
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--soft);
      }

      .wheel-center-value {
        margin-top: 6px;
        font-size: 28px;
        font-weight: 900;
        line-height: 1;
        letter-spacing: -0.04em;
        color: #fff4cf;
        text-shadow: 0 0 14px rgba(243, 213, 136, 0.14);
      }

      .wheel-node {
        position: absolute;
        transform: translate(-50%, -50%);
        width: 106px;
        text-align: center;
        transition: transform 0.18s ease, filter 0.18s ease;
      }

      .wheel-node:hover {
        transform: translate(-50%, -50%) scale(1.05);
        z-index: 3;
      }

      .wheel-flame-wrap {
        display: flex;
        justify-content: center;
        margin-bottom: 7px;
      }

      .wheel-flame {
        width: 18px;
        height: 34px;
        clip-path: polygon(50% 0%, 68% 18%, 82% 44%, 72% 74%, 50% 100%, 28% 74%, 18% 44%, 32% 18%);
        transition: all 0.25s ease;
      }

      .wheel-flame.on {
        background:
          radial-gradient(circle at 50% 18%, rgba(255,255,255,0.98), transparent 20%),
          radial-gradient(circle at 50% 42%, rgba(182, 241, 255, 0.95), rgba(115, 220, 255, 0.68) 48%, rgba(115, 220, 255, 0.08) 75%, transparent 85%);
        box-shadow:
          0 0 12px rgba(180, 240, 255, 0.55),
          0 0 26px rgba(115, 220, 255, 0.28),
          0 0 46px rgba(115, 220, 255, 0.14);
        animation: flamePulse 2.2s ease-in-out infinite, flameFloat 3.4s ease-in-out infinite;
      }

      .wheel-flame.off {
        background:
          linear-gradient(180deg, rgba(86, 100, 136, 0.22), rgba(36, 44, 68, 0.14));
        opacity: 0.55;
        filter: saturate(0.7);
      }

      .wheel-node-card {
        border-radius: 14px;
        border: 1px solid rgba(120, 170, 255, 0.12);
        background:
          linear-gradient(180deg, rgba(14, 20, 36, 0.88), rgba(10, 14, 26, 0.94));
        padding: 8px 8px 10px;
        min-height: 78px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 4px;
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.03),
          inset 0 -10px 18px rgba(0,0,0,0.24);
      }

      .wheel-node.unlocked .wheel-node-card {
        border-color: rgba(115, 220, 255, 0.20);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.04),
          inset 0 -10px 18px rgba(0,0,0,0.26),
          0 0 20px rgba(115, 220, 255, 0.06);
      }

      .wheel-node-symbol {
        font-size: 22px;
        line-height: 1;
      }

      .wheel-node-name {
        font-size: 13px;
        font-weight: 700;
        color: #eef3ff;
        line-height: 1.2;
      }

      .wheel-node-count {
        font-variant-numeric: tabular-nums;
        font-size: 15px;
        font-weight: 900;
        letter-spacing: 0.04em;
      }

      .wheel-node-count.on {
        color: #fff4cf;
        text-shadow: 0 0 10px rgba(255, 234, 170, 0.15);
      }

      .wheel-node-count.off {
        color: #6a7395;
      }

      .placeholder-grid {
        margin-top: 26px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .placeholder-card {
        padding: 22px;
        background:
          linear-gradient(180deg, rgba(14,18,32,0.96), rgba(10,14,24,0.96));
      }

      .placeholder-kicker {
        color: var(--cyan);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .placeholder-title {
        margin: 10px 0 8px;
        font-size: 22px;
        letter-spacing: -0.03em;
      }

      .placeholder-copy {
        color: var(--muted);
        line-height: 1.8;
        font-size: 14px;
      }

      @keyframes flamePulse {
        0%, 100% {
          transform: scale(1);
          opacity: 0.92;
        }
        50% {
          transform: scale(1.08);
          opacity: 1;
        }
      }

      @keyframes flameFloat {
        0%, 100% {
          transform: translateY(0px) scale(1);
        }
        50% {
          transform: translateY(-2px) scale(1.04);
        }
      }

      @media (max-width: 1120px) {
        .wheels-grid,
        .placeholder-grid,
        .stats-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .wrap {
          padding: 22px 16px 64px;
        }

        .hero-card,
        .gate-card,
        .placeholder-card,
        .wheel-panel {
          border-radius: 22px;
        }

        .hero-card,
        .gate-card {
          padding: 22px 18px;
        }

        .wheel-panel {
          padding: 18px 18px 22px;
        }

        .wheel-shell {
          width: min(100%, 420px);
        }

        .wheel-node {
          width: 82px;
        }

        .wheel-node-card {
          min-height: 66px;
          padding: 7px 6px 8px;
        }

        .wheel-node-symbol {
          font-size: 16px;
        }

        .wheel-node-name {
          font-size: 11px;
        }

        .wheel-node-count {
          font-size: 12px;
        }

        .wheel-center-value {
          font-size: 20px;
        }

        .stat-head {
          align-items: center;
        }

        .stat-title {
          font-size: 24px;
        }

        .stat-main {
          font-size: 30px;
        }
      }
    </style>
  </head>

  <body>
    <div class="wrap">
      <header class="topbar">
        <a class="back-link" href="/">← 返回首页</a>
        <a class="account-link" href={user ? '/account' : '/login'}>
          {user ? '我的账户' : '会员登录'}
        </a>
      </header>

      <section class="hero-card">
        <span class="eyebrow">夜色图鉴 / Collection</span>
        <h1>命盘点火，缘分留痕。</h1>
        <p class="hero-copy">
          有些相遇不会久留，但可以被记录、被命名、被点亮。
          本轮图鉴先记录十二星座与十二生肖。
          每出现一次，就在对应宫位留下一个计数；每解锁一种，就点燃一簇火。
        </p>

        <div class="stats-grid">
          <article class="stat-card">
            <div class="stat-kicker">Constellation</div>
            <div class="stat-head">
              <h2 class="stat-title">星座图鉴</h2>
              <div class="stat-main">{constellationStats.unlockedKinds} / 12</div>
            </div>
            <div class="stat-sub">本轮累计记录：{constellationStats.totalCount} 次</div>
          </article>

          <article class="stat-card">
            <div class="stat-kicker">Chinese Zodiac</div>
            <div class="stat-head">
              <h2 class="stat-title">生肖图鉴</h2>
              <div class="stat-main">{zodiacStats.unlockedKinds} / 12</div>
            </div>
            <div class="stat-sub">本轮累计记录：{zodiacStats.totalCount} 次</div>
          </article>
        </div>
      </section>

      {!user ? (
        <section class="gate-card">
          <h2 class="gate-title">请先登录以查看图鉴内容</h2>
          <p class="gate-copy">
            夜色图鉴属于会员收藏页。登录后可继续查看账户状态，并解锁后续付费内容。
          </p>
          <div class="gate-actions">
            <a class="button button-primary" href="/login">前往登录</a>
            <a class="button button-secondary" href="/">返回首页</a>
          </div>
        </section>
      ) : !hasPaidAccess ? (
        <section class="gate-card">
          <h2 class="gate-title">该内容为付费收藏内容</h2>
          <p class="gate-copy">
            你已登录，但当前没有有效付费权限。订阅后即可解锁完整图鉴页面与后续收藏内容。
          </p>
          <div class="gate-actions">
            <a class="button button-primary" href="/pricing">查看订阅方案</a>
            <a class="button button-secondary" href="/account">我的账户</a>
          </div>
        </section>
      ) : (
        <>
          <section class="wheels-grid">
            <CollectionWheel
              client:load
              title="十二星座"
              subtitle="Constellation Wheel"
              items={constellationItems}
              centerTop="已解锁 / 累计"
              centerBottom={`${constellationStats.unlockedKinds}/12 (${constellationStats.totalCount})`}
              mode="constellation"
            />

            <CollectionWheel
              client:load
              title="十二生肖"
              subtitle="Zodiac Wheel"
              items={zodiacItems}
              centerTop="已解锁 / 累计"
              centerBottom={`${zodiacStats.unlockedKinds}/12 (${zodiacStats.totalCount})`}
              mode="zodiac"
            />
          </section>

          <section class="placeholder-grid">
            <article class="placeholder-card">
              <div class="placeholder-kicker">Coming Soon</div>
              <h3 class="placeholder-title">国家图鉴</h3>
              <p class="placeholder-copy">
                建设中...
              </p>
            </article>

            <article class="placeholder-card">
              <div class="placeholder-kicker">Coming Soon</div>
              <h3 class="placeholder-title">城市图鉴</h3>
              <p class="placeholder-copy">
                建设中...
              </p>
            </article>

            <article class="placeholder-card">
              <div class="placeholder-kicker">Coming Soon</div>
              <h3 class="placeholder-title">特殊成就</h3>
              <p class="placeholder-copy">
                建设中...
              </p>
            </article>
          </section>
        </>
      )}
    </div>
  </body>
</html>